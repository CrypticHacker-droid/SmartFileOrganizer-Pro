{
  "language": "fr",
  "theme": "dark",
  "watch_folder": "",
  "auto_start": false,
  "minimize_to_tray": true,
  "notify_on_move": true,
  "skip_locked_files": true,
  "deep_clean": false,
  "default_categories": {
    "Images": [".jpg", ".jpeg", ".png", ".gif", ".bmp", ".svg", ".webp", ".ico", ".raw", ".tiff"],
    "Videos": [".mp4", ".mkv", ".avi", ".mov", ".wmv", ".flv", ".webm", ".m4v", ".mpg", ".mpeg"],
    "Documents": [".pdf", ".doc", ".docx", ".txt", ".xls", ".xlsx", ".ppt", ".pptx", ".odt", ".rtf", ".csv"],
    "Archives": [".zip", ".rar", ".7z", ".tar", ".gz", ".bz2", ".xz", ".iso"],
    "Audio": [".mp3", ".wav", ".flac", ".aac", ".ogg", ".m4a", ".wma", ".aiff"],
    "Code": [".py", ".js", ".html", ".css", ".cpp", ".c", ".java", ".json", ".xml", ".sql", ".sh", ".bat", ".php", ".rb"],
    "Executables": [".exe", ".msi", ".dmg", ".deb", ".app", ".pkg"],
    "Fonts": [".ttf", ".otf", ".woff", ".woff2", ".eot"]
  }
}